DATABASE_URL=postgresql://user:password@localhost:5432/logifinance
DIRECT_URL=postgresql://user:password@localhost:5432/logifinance
REDIS_URL=redis://localhost:6379

# Provider API base URLs (override for sandbox)
DHL_API_BASE_URL=https://express.api.dhl.com/mydhlapi
FEDEX_API_BASE_URL=https://apis.fedex.com
UPS_API_BASE_URL=https://onlinetools.ups.com

# Provider HTTP retry/timeout
PROVIDER_HTTP_TIMEOUT_MS=15000
PROVIDER_HTTP_RETRY_COUNT=2

# Webhook retry worker
WEBHOOK_RETRY_WORKER_ENABLED=true
WEBHOOK_RETRY_INTERVAL_MS=15000
WEBHOOK_RETRY_BATCH_SIZE=10
